{
 "cells": [
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "d = np.load('organsmnist_128.npz')\n",
    "X, y = d['train_images'].astype('float32')/255.0, d['train_labels'].flatten()\n",
    "X = X[..., None]\n",
    "L = ['Bladder','Femur-L','Femur-R','Heart','Kidney-L','Kidney-R','Liver','Lung-L','Lung-R','Pancreas','Spleen']\n",
    "print(X.shape)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 1. Samples"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(10,2))\n",
    "for i in range(5): plt.subplot(1,5,i+1), plt.imshow(X[np.random.randint(len(X)),...,0], 'gray'), plt.axis('off')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 2. Averages"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(12,4))\n",
    "for i in range(11): plt.subplot(2,6,i+1), plt.imshow(X[y==i].mean(0)[...,0], 'hot'), plt.title(L[i], color='cyan', fontsize=8), plt.axis('off')\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 3. Intensity"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(12,6))\n",
    "for i in range(11): plt.subplot(3,4,i+1), plt.hist(X[y==i].flatten(), 30, alpha=0.7), plt.title(L[i], fontsize=8)\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 4. Mirror Pairs (L vs R)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "P = [('Femur-L','Femur-R'), ('Kidney-L','Kidney-R'), ('Lung-L','Lung-R')]\n",
    "plt.figure(figsize=(12,6))\n",
    "for r, (ln, rn) in enumerate(P):\n",
    "    li, ri = np.where(y==L.index(ln))[0], np.where(y==L.index(rn))[0]\n",
    "    for c in range(3):\n",
    "        plt.subplot(3,6,r*6+c+1), plt.imshow(X[li[c],...,0], 'gray'), plt.title(ln, fontsize=7), plt.axis('off')\n",
    "        plt.subplot(3,6,r*6+c+4), plt.imshow(X[ri[c],...,0], 'gray'), plt.title(rn, fontsize=7), plt.axis('off')\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5. Liver Variance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "idx = np.where(y==6)[0]\n",
    "plt.figure(figsize=(10,2))\n",
    "for i in range(5): plt.subplot(1,5,i+1), plt.imshow(X[idx[i],...,0], 'magma'), plt.axis('off')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 6. Brightness"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(10,3))\n",
    "sns.boxplot(data=[X[y==i].mean((1,2,3)) for i in range(11)])\n",
    "plt.xticks(range(11), L, rotation=45, fontsize=8); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 7. Extremes"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "m = X.mean((1,2,3))\n",
    "plt.figure(figsize=(4,2))\n",
    "plt.subplot(121), plt.imshow(X[np.argmin(m),...,0], 'gray'), plt.axis('off')\n",
    "plt.subplot(122), plt.imshow(X[np.argmax(m),...,0], 'gray'), plt.axis('off')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 8. Structural Var"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(12,4))\n",
    "for i in range(11): plt.subplot(2,6,i+1), plt.imshow(X[y==i].std(0)[...,0], 'gnuplot'), plt.axis('off')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 9. Composition"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(5,5)), plt.pie(np.bincount(y), labels=L, autopct='%1.1f%%', textprops={'fontsize':7}), plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 10. Empty Check"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(f\"Black: {np.sum(X.max((1,2,3))==0)}\")"
   ]
  }
 ]
}
